{
  "expo": {
    "name": "Lernen",
    "slug": "lernen-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lernen",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "de.lernen.mobile",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F4F0E6",
        "foregroundImage": "./assets/images/adaptive-foreground.png",
        "monochromeImage": "./assets/images/adaptive-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "de.lernen.mobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-mark.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#F4F0E6",
          "dark": {
            "image": "./assets/images/splash-mark-dark.png",
            "backgroundColor": "#0A0A0A"
          }
        }
      ],
      "expo-font",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d988ea82-bc16-484c-811f-d28ab3516b53"
      }
    },
    "owner": "myautomakion",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d988ea82-bc16-484c-811f-d28ab3516b53"
    }
  }
}
