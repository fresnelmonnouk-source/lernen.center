# Lernen.de — mobile (Expo) public env vars
#
# SECURITY: Expo only exposes variables prefixed with EXPO_PUBLIC_ to the client
# bundle. NEVER put server secrets here (no DEEPSEEK_API_KEY, no Supabase
# service_role key). The bundle is public — anyone can read it.
# AI keys stay server-side on Vercel ([C-003]); the app only holds the values below.

# Base URL of the existing Vercel backend (the 14 endpoints).
EXPO_PUBLIC_API_BASE_URL=https://your-app.vercel.app

# Supabase public credentials (anon key is public by design, protected by RLS).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key
